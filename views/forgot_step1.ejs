<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Yatri 2.0 - Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; color: white; font-family: 'Segoe UI', Tahoma, sans-serif; }
        .glass-card { background: rgba(48, 43, 99, 0.6); border: 1px solid rgba(255, 215, 0, 0.2); padding: 40px; border-radius: 15px; width: 100%; max-width: 400px; backdrop-filter: blur(10px); }
        .form-control { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,215,0,0.3); }
        .form-control:focus { background: rgba(255,255,255,0.15); color: white; border-color: #FFD700; box-shadow: none; }
    </style>
</head>
<body>
    <div class="glass-card">
        <h3 class="text-center mb-4" style="color: #FFD700;">Reset Password</h3>
        <p class="text-center text-light mb-4">Enter your registered email to retrieve your security question.</p>
        <form action="/forgot-password/question" method="POST">
            <div class="mb-3">
                <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <button type="submit" class="btn btn-warning w-100 fw-bold">Next</button>
        </form>
        <div class="text-center mt-3">
            <a href="/login" class="text-decoration-none" style="color: #FFD700;"><small>Back to Login</small></a>
        </div>
    </div>
</body>
</html>