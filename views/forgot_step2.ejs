<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Yatri 2.0 - Security Question</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; color: white; font-family: 'Segoe UI', Tahoma, sans-serif; }
        .glass-card { background: rgba(48, 43, 99, 0.6); border: 1px solid rgba(255, 215, 0, 0.2); padding: 40px; border-radius: 15px; width: 100%; max-width: 450px; backdrop-filter: blur(10px); }
        .form-control { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,215,0,0.3); }
        .form-control:focus { background: rgba(255,255,255,0.15); color: white; border-color: #FFD700; box-shadow: none; }
    </style>
</head>
<body>
    <div class="glass-card">
        <h4 class="text-center mb-4" style="color: #FFD700;">Security Verification</h4>
        <form action="/forgot-password/reset" method="POST">
            <input type="hidden" name="email" value="<%= email %>">
            
            <div class="mb-3">
                <label class="form-label" style="color: #b0b0b0;">Security Question:</label>
                <p class="fw-bold"><%= question %></p>
            </div>

            <div class="mb-3">
                <input type="text" name="answer" class="form-control" placeholder="Your Answer" required>
            </div>

            <div class="mb-4">
                <label class="form-label" style="color: #b0b0b0;">New Password:</label>
                <input type="password" name="new_password" class="form-control" placeholder="Enter new password" required>
            </div>

            <button type="submit" class="btn btn-warning w-100 fw-bold">Reset Password</button>
        </form>
    </div>
</body>
</html>