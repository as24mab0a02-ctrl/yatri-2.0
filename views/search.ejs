<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yatri 2.0 - Search Results</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
            padding-bottom: 50px;
        }

        .navbar {
            background: rgba(15, 12, 41, 0.98) !important;
            border-bottom: 2px solid #FFD700;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            font-weight: 700;
            font-size: 24px;
        }

        .train-card {
            background: rgba(48, 43, 99, 0.6);
            border: 1px solid rgba(255, 215, 0, 0.2);
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            padding: 30px;
            margin-bottom: 30px;
            backdrop-filter: blur(10px);
            animation: fadeInUp 0.6s ease forwards;
        }

        .train-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .train-name {
            color: #FFD700;
            font-weight: 700;
            font-size: 22px;
            margin: 0;
        }

        .train-no {
            background: rgba(255, 215, 0, 0.2);
            color: #FFD700;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
        }

        /* TIMELINE GRAPH */
        .timeline-wrapper {
            position: relative;
            margin: 40px 0;
            padding: 0 20px;
        }

        .timeline-line {
            position: absolute;
            top: 15px;
            left: 50px;
            right: 50px;
            height: 3px;
            background: rgba(255, 215, 0, 0.3);
            z-index: 1;
        }

        .timeline-stops {
            display: flex;
            justify-content: space-between;
            position: relative;
            z-index: 2;
        }

        .stop-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 80px;
        }

        .stop-dot {
            width: 20px;
            height: 20px;
            background: #FFD700;
            border-radius: 50%;
            border: 4px solid #302b63;
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.6);
            margin-bottom: 10px;
            animation: pulse 2s infinite;
            box-shadow: 0 0 15px rgba(255, 255, 255, 0.8);
        }

        .stop-code {
            font-weight: 700;
            color: #fff;
            font-size: 14px;
            letter-spacing: 1px;
        }

        .stop-time {
            color: #b0b0b0;
            font-size: 12px;
        }

        /* SEAT AVAILABILITY */
        .seats-container {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            flex-wrap: wrap;
        }

        .seat-class-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 15px 20px;
            text-align: center;
            flex: 1;
            min-width: 120px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .seat-class-card:hover {
            background: rgba(255, 215, 0, 0.1);
            border-color: #FFD700;
            transform: translateY(-5px);
        }

        .class-name {
            font-size: 18px;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 5px;
        }

        .journey-date {
            color: #ffffff;
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .journey-date span {
            color: #ffd700;
            font-weight: 800;
        }

        .availability-heading {
            color: #f5f5f5;
            font-size: 0.9rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 0.75rem;
        }

        .status-green,
        .status-red {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            padding: 8px 14px;
            border-radius: 999px;
            min-width: 120px;
            font-weight: 700;
        }

        .status-green {
            color: #00e676;
            background: rgba(0, 230, 118, 0.15);
            border: 1px solid rgba(0, 230, 118, 0.3);
        }

        .status-red {
            color: #ff6b6b;
            background: rgba(255, 82, 82, 0.15);
            border: 1px solid rgba(255, 82, 82, 0.3);
        }

        .avl-status {
            font-size: 16px;
            font-weight: 600;
        }

        .status-green { color: #00e676; }
        .status-red { color: #ff5252; }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(255, 215, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0); }
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark mb-5">
        <div class="container">
            <a class="navbar-brand" href="#"><i class="fas fa-train"></i> Yatri 2.0</a>
            <a href="javascript:history.back()" class="btn btn-outline-light btn-sm"><i class="fas fa-arrow-left"></i> Modify Search</a>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4 text-center" style="color: #FFD700;">
            <i class="fas fa-route"></i> Trains from <strong><%= source %></strong> to <strong><%= destination %></strong>
        </h3>
        <p class="text-center journey-date mb-5">Journey Date: <span><%= date %></span></p>

        <% if (trains.length === 0) { %>
            <div class="alert alert-warning text-center" style="background: rgba(255, 193, 7, 0.1); border-color: #ffc107; color: #ffc107;">
                <i class="fas fa-exclamation-circle fa-2x mb-3"></i>
                <h5>No Trains Found!</h5>
                <p>Sorry, there are no direct or connecting trains available for this route on the selected date.</p>
            </div>
        <% } else { %>
            
            <% trains.forEach(train => { %>
                <div class="train-card">
                    
                    <!-- Train Header -->
                    <div class="train-header">
                        <h3 class="train-name"><%= train.train_name %></h3>
                        <span class="train-no"><i class="fas fa-hashtag"></i> <%= train.train_no %></span>
                    </div>

                    <!-- The Route Timeline Graph -->
                    <div class="timeline-wrapper">
                        <div class="timeline-line"></div>
                        <div class="timeline-stops">
                            <% train.stops.forEach(stop => { %>
                                <div class="stop-item">
                                    <div class="stop-dot" title="<%= stop.station_name %>"></div>
                                    <div class="stop-code"><%= stop.station_code %></div>
                                    <div class="stop-time">
                                        <%= stop.station_code === source ? stop.departure_time.substring(0,5) : stop.arrival_time.substring(0,5) %>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Seat Availability Cards -->
                    <h6 class="availability-heading"><i class="fas fa-chair"></i> Select Class to View Coach</h6>
                    <div class="seats-container">
                        <% if (train.classes.length === 0) { %>
                            <div class="w-100 text-center text-muted">No seat data configured for this train.</div>
                        <% } else { %>
                            <% train.classes.forEach(cls => { %>
                                <form action="/view-coach" method="POST" style="flex: 1; min-width: 120px;">
                                    
                                    <input type="hidden" name="train_no" value="<%= train.train_no %>">
                                    <input type="hidden" name="journey_date" value="<%= date %>">
                                    <input type="hidden" name="coach_class" value="<%= cls.coach_class %>">
                                    <input type="hidden" name="start_seq" value="<%= train.start_seq %>">
                                    <input type="hidden" name="end_seq" value="<%= train.end_seq %>">
                                    <input type="hidden" name="source" value="<%= source %>">
                                    <input type="hidden" name="destination" value="<%= destination %>">

                                    <button type="submit" class="seat-class-card w-100" style="border:none; appearance: none; display:block;">
                                        <div class="class-name"><%= cls.coach_class %></div>
                                        
                                        <% if (parseInt(cls.available_seats) > 0) { %>
                                            <div class="avl-status status-green">
                                                AVL - <%= cls.available_seats %>
                                            </div>
                                        <% } else { %>
                                            <div class="avl-status status-red">
                                                WL - <%= Math.abs(parseInt(cls.available_seats)) %>
                                            </div>
                                        <% } %>
                                    </button>
                                </form>
                            <% }) %>
                        <% } %>
                    </div>

                </div>
            <% }) %>
        <% } %>
    </div>
</body>
</html>