<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yatri 2.0 - Select Seat</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
            padding-bottom: 50px;
        }

        .navbar {
            background: rgba(15, 12, 41, 0.98) !important;
            border-bottom: 2px solid #FFD700;
        }

        .journey-header {
            background: rgba(48, 43, 99, 0.8);
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }

        .journey-header h3 { color: #FFD700; margin-bottom: 10px;}
        .journey-header p { margin: 0; color: #b0b0b0; font-size: 16px;}

        /* CSS Grid Coach Layout */
        .coach-container {
            background: #e0e0e0; /* Train floor color */
            border-radius: 20px;
            padding: 30px 15px;
            max-width: 400px;
            margin: 0 auto;
            border: 5px solid #1a1a1a;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5), 0 10px 30px rgba(0,0,0,0.5);
        }

        .coach-grid {
            display: grid;
            /* 3 left seats, 1 aisle gap, 2 right side seats */
            grid-template-columns: 1fr 1fr 1fr 2fr 1fr 1fr; 
            gap: 10px;
            justify-items: center;
        }

        .seat {
            width: 45px;
            height: 45px;
            border-radius: 8px 8px 0 0; /* Looks like a chair back */
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 12px;
            color: #1a1a1a;
            border: 2px solid #555;
            transition: transform 0.2s;
            position: relative;
        }

        /* If seat is booked, make it red and unclickable */
        .seat.booked {
            background-color: #ff5252;
            cursor: not-allowed;
            opacity: 0.6;
        }

        /* If seat is available, make it green and clickable */
        .seat.available {
            background-color: #00e676;
            cursor: pointer;
        }

        .seat.available:hover {
            transform: scale(1.1);
            box-shadow: 0 0 10px rgba(0, 230, 118, 0.8);
        }

        /* Selection styling */
        .seat-radio {
            display: none; /* Hide the actual radio input */
        }

        .seat-radio:checked + .seat.available {
            background-color: #FFD700; /* Turns yellow when clicked! */
            border-color: #b39700;
            transform: scale(1.1);
            box-shadow: 0 0 15px #FFD700;
        }

        /* Legend */
        .legend {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 14px; }
        .box { width: 20px; height: 20px; border-radius: 4px; border: 1px solid #fff; }
        .box.avail { background: #00e676; }
        .box.book { background: #ff5252; }
        .box.sel { background: #FFD700; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="#"><i class="fas fa-train"></i> Yatri 2.0</a>
            <a href="javascript:history.back()" class="btn btn-outline-light btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
        </div>
    </nav>

    <div class="container">
        
        <div class="journey-header">
            <h3>Train <%= train_no %> | Class: <%= coach_class %></h3>
            <p><strong><%= source %></strong> to <strong><%= destination %></strong> | Date: <%= journey_date %></p>
        </div>

        <h4 class="text-center mb-3">Select Your Seat</h4>

        <form action="/book" method="POST">
            <input type="hidden" name="coach_class" value="<%= coach_class %>">
            <input type="hidden" name="train_no" value="<%= train_no %>">
            <input type="hidden" name="journey_date" value="<%= journey_date %>">
            <input type="hidden" name="source" value="<%= source %>">
            <input type="hidden" name="destination" value="<%= destination %>">
            <input type="hidden" name="start_seq" value="<%= start_seq %>">
            <input type="hidden" name="end_seq" value="<%= end_seq %>">

            <div class="coach-container">
                <div class="coach-grid">
                    <% seats.forEach((seat, index) => { %>
                        
                        <% if (seat.status === 'AVAILABLE') { %>
                            <label>
                                <input type="radio" name="seat_id" value="<%= seat.seat_id %>" class="seat-radio" required>
                                <div class="seat available" title="Seat <%= seat.seat_id %>">
                                    <%= index + 1 %>
                                </div>
                            </label>
                        <% } else { %>
                            <div>
                                <div class="seat booked" title="Seat <%= seat.seat_id %> is Booked">
                                    <i class="fas fa-times"></i>
                                </div>
                            </div>
                        <% } %>

                    <% }) %>
                </div>
            </div>

            <div class="legend">
                <div class="legend-item"><div class="box avail"></div> Available</div>
                <div class="legend-item"><div class="box book"></div> Booked</div>
                <div class="legend-item"><div class="box sel"></div> Selected</div>
            </div>

            <div class="text-center mt-5">
                <button type="submit" class="btn btn-warning btn-lg fw-bold px-5">Confirm Booking</button>
            </div>
        </form>

    </div>
</body>
</html>