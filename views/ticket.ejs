<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yatri 2.0 - E-Ticket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 40px 0;
        }
        .ticket-wrapper {
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
            border-top: 8px solid #FFD700;
        }
        .ticket-header {
            background: #302b63;
            color: #fff;
            padding: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .pnr-box {
            background: rgba(255, 215, 0, 0.2);
            border: 1px solid #FFD700;
            padding: 10px 20px;
            border-radius: 8px;
            text-align: center;
        }
        .ticket-body { padding: 40px; }
        .journey-block {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 30px;
            border-bottom: 2px dashed #ddd;
        }
        .station { text-align: center; }
        .station h3 { margin: 0; color: #302b63; font-weight: bold; }
        .train-icon { font-size: 24px; color: #b0b0b0; }
        .detail-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            border-left: 4px solid #302b63;
        }
        .status-badge {
            background: #00e676;
            color: #000;
            font-weight: bold;
            padding: 5px 15px;
            border-radius: 20px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="text-center mb-4">
            <a href="/dashboard" class="btn btn-outline-dark"><i class="fas fa-home"></i> Back to Dashboard</a>
        </div>

        <div class="ticket-wrapper">
            <div class="ticket-header">
                <div>
                    <h2 class="mb-0"><i class="fas fa-train"></i> Yatri 2.0 E-Ticket</h2>
                    <p class="mb-0 mt-2 text-light">Train: <%= ticket.train_name %> (<%= ticket.train_no %>)</p>
                </div>
                <div class="pnr-box">
                    <small class="text-uppercase" style="color: #FFD700;">PNR Number</small>
                    <h3 class="mb-0" style="color: #fff;"><%= ticket.pnr %></h3>
                </div>
            </div>

            <div class="ticket-body">
                <div class="journey-block">
                    <div class="station">
                        <small class="text-muted">From</small>
                        <h3><%= ticket.source_name %></h3>
                    </div>
                    <div class="train-icon">
                        <i class="fas fa-long-arrow-alt-right"></i>
                        <i class="fas fa-train"></i>
                        <i class="fas fa-long-arrow-alt-right"></i>
                    </div>
                    <div class="station">
                        <small class="text-muted">To</small>
                        <h3><%= ticket.destination_name %></h3>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="detail-box">
                            <small class="text-muted text-uppercase fw-bold">Passenger Details</small>
                            <h5 class="mt-2 mb-1"><i class="fas fa-user"></i> <%= ticket.full_name %></h5>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-box">
                            <small class="text-muted text-uppercase fw-bold">Journey Date</small>
                            <h5 class="mt-2 mb-1"><i class="fas fa-calendar-alt"></i> <%= ticket.journey_date.toISOString().split('T')[0] %></h5>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-box">
                            <small class="text-muted text-uppercase fw-bold">Class / Seat</small>
                            <h5 class="mt-2 mb-1"><%= ticket.coach_class %> | <%= ticket.seat_id %></h5>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-box">
                            <small class="text-muted text-uppercase fw-bold">Total Fare</small>
                            <h5 class="mt-2 mb-1 text-success">₹<%= ticket.fare %></h5>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="detail-box text-center">
                            <small class="text-muted text-uppercase fw-bold d-block mb-2">Status</small>
                            <span class="status-badge"><%= ticket.status %></span>
                        </div>
                    </div>
                </div>
                
                <div class="text-center mt-4">
                    <button class="btn btn-secondary" onclick="window.print()"><i class="fas fa-print"></i> Print Ticket</button>
                </div>
            </div>
        </div>
    </div>

</body>
</html>